extends ../layouts/app
include ../mixins/ui

block content
  -
    function fmtDate(d) { return d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—'; }
    function userName(u) { if (!u) return '—'; var n = ((u.first_name || '') + ' ' + (u.last_name || '')).trim(); return n || u.email || ('User #' + u.id); }
    function buildHref(page) {
      var qs = ['page=' + page];
      if (userTypeFilter) qs.push('user_type=' + encodeURIComponent(userTypeFilter));
      if (statusFilter) qs.push('status=' + statusFilter);
      if (q) qs.push('q=' + encodeURIComponent(q));
      return '/admin/users?' + qs.join('&');
    }

  div(x-data="{ suspendOpen: false, target: { id: 0, name: '' }, reactivateOpen: false, resetOpen: false }")
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Users
        h1.text-2xl.font-bold.text-gray-900 User Management
        p.text-gray-500.mt-1 Monitor user accounts, permissions, and engagement.

    //- Stat cards
    .grid.gap-5.mb-6(class="grid-cols-1 sm:grid-cols-3")
      +statCard({ label: 'Total Users', value: stats.total.toLocaleString('en-US'), delta: null, icon: 'users' })
      +statCard({ label: 'Active', value: stats.active.toLocaleString('en-US'), delta: null, icon: 'user-check' })
      +statCard({ label: 'Suspended', value: stats.suspended.toLocaleString('en-US'), delta: null, icon: 'user-x' })

    include ../partials/flash

    //- Filters
    .bg-white.rounded-xl.border.border-gray-200.mb-6(class="p-4")
      form.grid.gap-3(method="GET" action="/admin/users" class="grid-cols-1 md:grid-cols-12")
        div(class="md:col-span-6")
          label.block.text-xs.font-medium.text-gray-500.mb-1 Search
          .relative
            i(data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400")
            input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="pl-9 pr-3" type="search" name="q" value=q placeholder="Name, email, or phone…")
        div(class="md:col-span-3")
          label.block.text-xs.font-medium.text-gray-500.mb-1 User type
          select.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" name="user_type")
            option(value="" selected=(userTypeFilter === null)) All types
            each t in userTypes
              option(value=t selected=(userTypeFilter === t))= t
        div(class="md:col-span-2")
          label.block.text-xs.font-medium.text-gray-500.mb-1 Status
          select.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" name="status")
            option(value="" selected=(statusFilter === null)) All
            each s in statuses
              option(value=s selected=(statusFilter === s))= s
        div(class="md:col-span-1 flex items-end")
          button.w-full.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="py-2 hover:bg-primary-700" type="submit") Apply

    //- Table
    if users.length === 0
      .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
        i(data-lucide="users" class="w-10 h-10 mb-3")
        p.text-sm No users match these filters.
    else
      .bg-white.rounded-xl.border.border-gray-200.overflow-hidden
        table.w-full.text-sm
          thead.bg-gray-50.text-gray-500
            tr
              th.text-left.font-medium(class="px-4 py-3") User
              th.text-left.font-medium(class="px-4 py-3") Email
              th.text-left.font-medium(class="px-4 py-3") Phone
              th.text-left.font-medium(class="px-4 py-3") Type
              th.text-left.font-medium(class="px-4 py-3") Joined
              th.text-left.font-medium(class="px-4 py-3") Status
              th.text-right.font-medium(class="px-4 py-3") Actions
          tbody.divide-y.divide-gray-100
            each u in users
              - var name = userName(u)
              - var status = u.deleted_at ? 'suspended' : 'active'
              - var payload = JSON.stringify({ id: u.id, name })
              tr(class="hover:bg-gray-50")
                td(class="px-4 py-3")
                  .flex.items-center.gap-3
                    if u.profile_picture
                      img.rounded-full.bg-gray-100.object-cover.shrink-0(class="w-9 h-9" src=u.profile_picture alt="")
                    else
                      .rounded-full.bg-primary-100.text-primary-700.flex.items-center.justify-center.text-xs.font-semibold.shrink-0(class="w-9 h-9")= ((u.first_name || ' ')[0] + (u.last_name || ' ')[0]).toUpperCase().trim() || '?'
                    div(class="min-w-0")
                      p.text-gray-900.font-medium.truncate= name
                      p.text-xs.text-gray-400 U#{String(u.id).padStart(3, '0')}
                td.text-gray-700(class="px-4 py-3")= u.email
                td.text-gray-700(class="px-4 py-3")= u.phone || '—'
                td.text-gray-700(class="px-4 py-3")= u.user_type || '—'
                td.text-gray-700(class="px-4 py-3")= fmtDate(u.created_at)
                td(class="px-4 py-3")
                  +statusPill(status)
                td.text-right(class="px-4 py-3")
                  button.inline-flex.items-center.gap-1.text-sm.text-gray-600.mr-1(class="px-2.5 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50" type="button" title="View profile" hx-get=`/admin/users/${u.id}/profile` hx-target="#user-modal-mount" hx-swap="innerHTML")
                    i(data-lucide="eye" class="w-4 h-4")
                  if status === 'active'
                    button.inline-flex.items-center.gap-1.text-sm.text-amber-700.mr-1(class="px-2.5 py-1.5 rounded-lg border border-amber-100 hover:bg-amber-50" type="button" title="Suspend" "@click"=`target = ${payload}; suspendOpen = true`)
                      i(data-lucide="ban" class="w-4 h-4")
                  else
                    button.inline-flex.items-center.gap-1.text-sm.text-green-700.mr-1(class="px-2.5 py-1.5 rounded-lg border border-green-100 hover:bg-green-50" type="button" title="Reactivate" "@click"=`target = ${payload}; reactivateOpen = true`)
                      i(data-lucide="user-check" class="w-4 h-4")
                  button.inline-flex.items-center.gap-1.text-sm.text-gray-600(class="px-2.5 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50" type="button" title="Reset password" "@click"=`target = ${payload}; resetOpen = true`)
                    i(data-lucide="key-round" class="w-4 h-4")

    +pagination(pagination, buildHref)

    //- Mount point for the htmx-fetched profile modal
    #user-modal-mount

    //- Suspend modal
    div(x-show="suspendOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="suspendOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
        h3.text-lg.font-semibold.text-gray-900 Suspend User
        p.text-sm.text-gray-500.mt-1 The user will be unable to log in until reactivated.
        p.text-sm.text-gray-600.mt-4 Suspend
          |
          span.font-medium.text-gray-900(x-text="target.name")
          | ?
        form.flex.justify-end.gap-3.mt-6(method="POST" ":action"="`/admin/users/${target.id}/suspend`")
          button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="suspendOpen = false") Cancel
          button.px-4.py-2.rounded-lg.bg-amber-600.text-white.text-sm.font-medium(class="hover:bg-amber-700" type="submit") Suspend Account

    //- Reactivate modal
    div(x-show="reactivateOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="reactivateOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
        h3.text-lg.font-semibold.text-gray-900 Reactivate User
        p.text-sm.text-gray-500.mt-1 The user will regain access immediately.
        p.text-sm.text-gray-600.mt-4 Reactivate
          |
          span.font-medium.text-gray-900(x-text="target.name")
          | ?
        form.flex.justify-end.gap-3.mt-6(method="POST" ":action"="`/admin/users/${target.id}/reactivate`")
          button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="reactivateOpen = false") Cancel
          button.px-4.py-2.rounded-lg.bg-green-600.text-white.text-sm.font-medium(class="hover:bg-green-700" type="submit") Reactivate

    //- Reset-password modal
    div(x-show="resetOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="resetOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
        h3.text-lg.font-semibold.text-gray-900 Send Password Reset
        p.text-sm.text-gray-500.mt-1 An email with a reset token will be sent to the user.
        p.text-sm.text-gray-600.mt-4 Send reset link to
          |
          span.font-medium.text-gray-900(x-text="target.name")
          | ?
        form.flex.justify-end.gap-3.mt-6(method="POST" ":action"="`/admin/users/${target.id}/reset-password`")
          button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="resetOpen = false") Cancel
          button.px-4.py-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="hover:bg-primary-700" type="submit") Send Reset Link
