extends ../layouts/app
include ../mixins/ui

block content
  -
    var first = me.first_name || ''
    var last = me.last_name || ''
    var initials = ((first[0] || 'A') + (last[0] || 'U')).toUpperCase()
    var roleName = me.super_role && me.super_role[0] ? me.super_role[0].name : 'Administrator'

  div
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Settings
        h1.text-2xl.font-bold.text-gray-900 Settings
        p.text-gray-500.mt-1 Manage your admin profile, security, and team.

    include _tabs
    include ../partials/flash

    .grid.gap-6(class="grid-cols-1 lg:grid-cols-3")
      //- Identity card
      .bg-white.rounded-xl.border.border-gray-200.p-6(class="lg:col-span-1 self-start")
        .flex.flex-col.items-center.text-center
          .rounded-full.bg-primary-600.text-white.flex.items-center.justify-center.text-2xl.font-semibold(class="w-20 h-20")= initials
          p.font-semibold.text-gray-900.mt-3= (first + ' ' + last).trim() || me.email
          p.text-sm.text-gray-500= me.email
          .mt-3
            +statusPill('active', roleName)
        if me.super_role && me.super_role.length
          .mt-6
            p.text-xs.font-medium.text-gray-500.mb-2 Roles
            .flex.flex-wrap.gap-1
              each r in me.super_role
                span.rounded.bg-gray-100.text-gray-700.text-xs.font-medium(class="px-2 py-0.5")= r.name

      //- Editable forms
      div(class="lg:col-span-2 space-y-6")
        //- Profile info form
        .bg-white.rounded-xl.border.border-gray-200.p-6
          h3.font-semibold.text-gray-900.mb-1 Profile Information
          p.text-sm.text-gray-500.mb-4 Visible to other admins.
          form.space-y-4(method="POST" action="/admin/settings/profile")
            .grid.gap-4(class="grid-cols-1 sm:grid-cols-2")
              div
                label.block.text-sm.font-medium.text-gray-700.mb-1(for="first_name") First name
                input#first_name.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="text" name="first_name" value=me.first_name required)
              div
                label.block.text-sm.font-medium.text-gray-700.mb-1(for="last_name") Last name
                input#last_name.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="text" name="last_name" value=me.last_name required)
              div(class="sm:col-span-2")
                label.block.text-sm.font-medium.text-gray-700.mb-1(for="email") Email
                input#email.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="email" name="email" value=me.email required)
            .flex.justify-end
              button.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="px-4 py-2 hover:bg-primary-700" type="submit") Save Changes

        //- Change password form
        .bg-white.rounded-xl.border.border-gray-200.p-6
          h3.font-semibold.text-gray-900.mb-1 Change Password
          p.text-sm.text-gray-500.mb-4 You'll stay signed in on this device after changing.
          form.space-y-4(method="POST" action="/admin/settings/profile/password")
            div
              label.block.text-sm.font-medium.text-gray-700.mb-1(for="current_password") Current password
              input#current_password.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="password" name="current_password" required autocomplete="current-password")
            .grid.gap-4(class="grid-cols-1 sm:grid-cols-2")
              div
                label.block.text-sm.font-medium.text-gray-700.mb-1(for="new_password") New password
                input#new_password.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="password" name="new_password" required minlength="8" autocomplete="new-password")
                p.text-xs.text-gray-400.mt-1 At least 8 characters.
              div
                label.block.text-sm.font-medium.text-gray-700.mb-1(for="confirm_password") Confirm new password
                input#confirm_password.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="password" name="confirm_password" required minlength="8" autocomplete="new-password")
            .flex.justify-end
              button.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="px-4 py-2 hover:bg-primary-700" type="submit") Update Password
