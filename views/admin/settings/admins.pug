extends ../layouts/app
include ../mixins/ui

block content
  -
    var fmtDate = function(d) { return d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—'; };
    var fullName = function(a) { var n = ((a.first_name || '') + ' ' + (a.last_name || '')).trim(); return n || a.email; };

  div(x-data="{ createOpen: false, deleteOpen: false, target: { id: 0, name: '' } }")
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          a(href="/admin/settings/profile" class="hover:text-gray-700") Settings
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Admins
        h1.text-2xl.font-bold.text-gray-900 Settings
        p.text-gray-500.mt-1 The team with access to this dashboard.
      button.inline-flex.items-center.gap-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="px-4 py-2 hover:bg-primary-700" type="button" "@click"="createOpen = true")
        i(data-lucide="user-plus" class="w-4 h-4")
        span Add Admin

    include _tabs
    include ../partials/flash

    if admins.length === 0
      .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
        i(data-lucide="shield" class="w-10 h-10 mb-3")
        p.text-sm No admins yet.
    else
      .bg-white.rounded-xl.border.border-gray-200.overflow-hidden
        table.w-full.text-sm
          thead.bg-gray-50.text-gray-500
            tr
              th.text-left.font-medium(class="px-4 py-3") Admin
              th.text-left.font-medium(class="px-4 py-3") Email
              th.text-left.font-medium(class="px-4 py-3") Roles
              th.text-left.font-medium(class="px-4 py-3") Joined
              th.text-right.font-medium(class="px-4 py-3") Actions
          tbody.divide-y.divide-gray-100
            each a in admins
              - var isMe = (a.id === currentAdminId)
              - var name = fullName(a)
              - var initials = ((a.first_name || ' ')[0] + (a.last_name || ' ')[0]).toUpperCase().trim() || '?'
              - var payload = JSON.stringify({ id: a.id, name })
              tr(class="hover:bg-gray-50")
                td(class="px-4 py-3")
                  .flex.items-center.gap-3
                    .rounded-full.bg-primary-100.text-primary-700.flex.items-center.justify-center.text-xs.font-semibold(class="w-9 h-9")= initials
                    div
                      p.text-gray-900.font-medium= name
                      if isMe
                        p.text-xs.text-primary-600 You
                td.text-gray-700(class="px-4 py-3")= a.email
                td(class="px-4 py-3")
                  if a.super_role && a.super_role.length
                    each r in a.super_role
                      span.inline-block.rounded.bg-gray-100.text-gray-700.text-xs.font-medium.mr-1.mb-1(class="px-2 py-0.5")= r.name
                  else
                    span.text-xs.text-gray-400 No roles
                td.text-gray-700(class="px-4 py-3")= fmtDate(a.created_at)
                td.text-right(class="px-4 py-3")
                  if isMe
                    span.text-xs.text-gray-400 —
                  else
                    button.inline-flex.items-center.gap-1.text-sm.text-red-600(class="px-2.5 py-1.5 rounded-lg border border-red-100 hover:bg-red-50" type="button" "@click"=`target = ${payload}; deleteOpen = true`)
                      i(data-lucide="trash-2" class="w-4 h-4")
                      span Remove

    //- Create modal
    div(x-show="createOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="createOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6.overflow-y-auto(class="max-w-lg mx-4 max-h-[90vh]")
        .flex.items-start.justify-between.mb-4
          div
            h3.text-lg.font-semibold.text-gray-900 Add Admin
            p.text-sm.text-gray-500.mt-1 The new admin will sign in with the email and password you set.
          button.text-gray-400(type="button" "@click"="createOpen = false")
            i(data-lucide="x" class="w-5 h-5")
        form.space-y-4(method="POST" action="/admin/settings/admins")
          .grid.gap-4(class="grid-cols-1 sm:grid-cols-2")
            div
              label.block.text-sm.font-medium.text-gray-700.mb-1 First name
              input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="text" name="first_name" required)
            div
              label.block.text-sm.font-medium.text-gray-700.mb-1 Last name
              input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="text" name="last_name" required)
            div(class="sm:col-span-2")
              label.block.text-sm.font-medium.text-gray-700.mb-1 Email
              input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="email" name="email" required)
            div(class="sm:col-span-2")
              label.block.text-sm.font-medium.text-gray-700.mb-1 Initial password
              input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" type="text" name="password" required minlength="8" placeholder="At least 8 characters")
              p.text-xs.text-gray-400.mt-1 The new admin can change this from their own Profile tab.
          if roles.length
            div
              label.block.text-sm.font-medium.text-gray-700.mb-2 Roles
              .grid.gap-2(class="grid-cols-1 sm:grid-cols-2")
                each r in roles
                  label.flex.items-start.gap-2.text-sm.text-gray-700.rounded-lg.border.border-gray-200(class="px-3 py-2")
                    input(class="mt-0.5" type="checkbox" name="role_ids" value=r.id)
                    div
                      p.font-medium= r.name
                      if r.description
                        p.text-xs.text-gray-500= r.description
          .flex.justify-end.gap-3.mt-2
            button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="createOpen = false") Cancel
            button.px-4.py-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="hover:bg-primary-700" type="submit") Create Admin

    //- Delete confirm
    div(x-show="deleteOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="deleteOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
        h3.text-lg.font-semibold.text-gray-900 Remove Admin
        p.text-sm.text-gray-500.mt-1 They will lose access to this dashboard.
        p.text-sm.text-gray-600.mt-4 Remove
          |
          span.font-medium.text-gray-900(x-text="target.name")
          | ?
        form.flex.justify-end.gap-3.mt-6(method="POST" ":action"="`/admin/settings/admins/${target.id}/delete`")
          button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="deleteOpen = false") Cancel
          button.px-4.py-2.rounded-lg.bg-red-600.text-white.text-sm.font-medium(type="submit") Remove
