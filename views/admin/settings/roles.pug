extends ../layouts/app
include ../mixins/ui

block content
  div
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          a(href="/admin/settings/profile" class="hover:text-gray-700") Settings
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Roles
        h1.text-2xl.font-bold.text-gray-900 Settings
        p.text-gray-500.mt-1 Available roles and the permissions they grant.

    include _tabs
    include ../partials/flash

    if roles.length === 0
      .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
        i(data-lucide="shield" class="w-10 h-10 mb-3")
        p.text-sm No roles configured.
    else
      .grid.gap-5(class="grid-cols-1 lg:grid-cols-2")
        each r in roles
          .bg-white.rounded-xl.border.border-gray-200.p-6
            .flex.items-start.gap-3.mb-3
              .rounded-lg.bg-primary-50.text-primary-600.flex.items-center.justify-center.shrink-0(class="w-10 h-10")
                i(data-lucide="shield-check" class="w-5 h-5")
              div(class="min-w-0 flex-1")
                p.font-semibold.text-gray-900= r.name
                if r.description
                  p.text-sm.text-gray-500.mt-1= r.description
            div
              p.text-xs.font-medium.text-gray-500.mb-2 Permissions (#{(r.super_permission || []).length})
              if r.super_permission && r.super_permission.length
                div(class="flex flex-wrap gap-1.5")
                  each p in r.super_permission
                    span.rounded.bg-gray-100.text-gray-700.text-xs.font-medium(class="px-2 py-0.5" title=(p.description || ''))= p.name
              else
                p.text-xs.text-gray-400 No permissions assigned.

    //- Reference: the global permission catalogue
    .mt-8
      h3.font-semibold.text-gray-900.mb-3 All available permissions
      if permissions.length === 0
        p.text-sm.text-gray-500 No permissions defined yet.
      else
        .bg-white.rounded-xl.border.border-gray-200.p-6
          .flex.flex-wrap.gap-2
            each p in permissions
              span.rounded.bg-gray-100.text-gray-700.text-xs.font-medium(class="px-2 py-1" title=(p.description || ''))= p.name
