extends layouts/app
include mixins/ui

block content
  -
    var chartData = {
      userGrowth: userGrowth,
      storePerformance: storePerformance,
      subscriptionDistribution: subscriptionDistribution
    }
    var chartJson = JSON.stringify(chartData).replace(/</g, '\\u003c')

  .mb-6
    h1.text-2xl.font-bold.text-gray-900 Dashboard Overview
    p.text-gray-500.mt-1 Welcome back! Here's what's happening with Autopadi today.

  //- Stat cards
  .grid.gap-5.mb-6(class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-4")
    each stat in stats
      +statCard(stat)

  //- Charts row
  .grid.gap-5.mb-6(class="grid-cols-1 lg:grid-cols-2")
    +panel('User Growth')
      .relative(class="h-64")
        canvas#chart-user-growth
    +panel('Store Performance')
      .relative(class="h-64")
        canvas#chart-store-performance
      if storePerformance.data.length === 0
        p.text-center.text-xs.text-gray-400.mt-2 No store activity yet.

  //- Lower row
  .grid.gap-5.mb-6(class="grid-cols-1 lg:grid-cols-2")
    +panel('Active Subscriptions')
      if subscriptionDistribution.length === 0
        +comingSoon('No subscribers yet')
      else
        .grid.gap-4(class="grid-cols-1 sm:grid-cols-2 items-center")
          .relative(class="h-48")
            canvas#chart-subscriptions
          ul.space-y-2
            each slice in subscriptionDistribution
              li.flex.items-center.gap-3
                span.inline-block.rounded-full(class="w-3 h-3" style=`background-color: ${slice.color}`)
                span.text-sm.text-gray-700.flex-1= slice.label
                span.text-sm.font-medium.text-gray-900= `${slice.percent}%`
    +panel('Recent Activities')
      if recentActivities.length === 0
        +comingSoon('No activity yet')
      else
        ul.divide-y.divide-gray-100
          each item in recentActivities
            li.flex.items-start.gap-3.py-3
              .rounded-lg.bg-gray-100.text-gray-500.flex.items-center.justify-center.shrink-0(class="w-9 h-9")
                i(data-lucide=item.icon class="w-4 h-4")
              .flex-1.min-w-0
                p.text-sm.font-medium.text-gray-900.truncate= item.title
                p.text-xs.text-gray-500.truncate= item.subtitle
              span.text-xs.text-gray-400.shrink-0= item.ago

  //- Quick actions
  +panel('Quick Actions')
    .flex.flex-wrap.gap-3
      a.inline-flex.items-center.gap-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="px-4 py-2 hover:bg-primary-700" href="/admin/communication")
        i(data-lucide="bell" class="w-4 h-4")
        span Send Notification
      a.inline-flex.items-center.gap-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(class="px-4 py-2 hover:bg-gray-50" href="/admin/settings")
        i(data-lucide="user-plus" class="w-4 h-4")
        span Add Admin
      a.inline-flex.items-center.gap-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(class="px-4 py-2 hover:bg-gray-50" href="/admin/reports")
        i(data-lucide="file-text" class="w-4 h-4")
        span View Reports

  script(type="application/json" id="overview-data")!= chartJson
  script.
    (function () {
      if (typeof Chart === 'undefined') return;
      var data = JSON.parse(document.getElementById('overview-data').textContent);
      var primary = '#2563EB';
      var grid = { color: '#F3F4F6', drawBorder: false };
      var tickFont = { family: 'Inter, sans-serif', size: 11 };

      var growthCanvas = document.getElementById('chart-user-growth');
      if (growthCanvas) {
        new Chart(growthCanvas, {
          type: 'line',
          data: {
            labels: data.userGrowth.labels,
            datasets: [{
              label: 'users',
              data: data.userGrowth.data,
              borderColor: primary,
              backgroundColor: 'rgba(37,99,235,0.08)',
              tension: 0.35, fill: true, pointRadius: 4, pointBackgroundColor: primary,
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: true, position: 'bottom', labels: { color: primary, font: tickFont } } },
            scales: {
              x: { grid: { display: false }, ticks: { font: tickFont, color: '#6B7280' } },
              y: { grid: grid, ticks: { font: tickFont, color: '#6B7280', precision: 0 }, beginAtZero: true }
            }
          }
        });
      }

      var perfCanvas = document.getElementById('chart-store-performance');
      if (perfCanvas) {
        new Chart(perfCanvas, {
          type: 'bar',
          data: {
            labels: data.storePerformance.labels,
            datasets: [{
              label: data.storePerformance.metricLabel || 'value',
              data: data.storePerformance.data,
              backgroundColor: primary, borderRadius: 6, maxBarThickness: 48
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: true, position: 'bottom', labels: { color: primary, font: tickFont } } },
            scales: {
              x: { grid: { display: false }, ticks: { font: tickFont, color: '#6B7280' } },
              y: { grid: grid, ticks: { font: tickFont, color: '#6B7280', precision: 0 }, beginAtZero: true }
            }
          }
        });
      }

      var subCanvas = document.getElementById('chart-subscriptions');
      if (subCanvas && data.subscriptionDistribution.length) {
        new Chart(subCanvas, {
          type: 'doughnut',
          data: {
            labels: data.subscriptionDistribution.map(function (s) { return s.label; }),
            datasets: [{
              data: data.subscriptionDistribution.map(function (s) { return s.value; }),
              backgroundColor: data.subscriptionDistribution.map(function (s) { return s.color; }),
              borderWidth: 0
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false, cutout: '0%',
            plugins: { legend: { display: false } }
          }
        });
      }
    })();
