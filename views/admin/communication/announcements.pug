extends ../layouts/app
include ../mixins/ui

block content
  -
    function fmtDate(d) { return d ? new Date(d).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—'; }
    function buildHref(page) { return '/admin/communication/announcements?page=' + page; }

  div
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Communication
        h1.text-2xl.font-bold.text-gray-900 Communication Center
        p.text-gray-500.mt-1 Broadcast in-app + push notifications to all users or a specific audience.

    include _tabs
    include ../partials/flash

    .grid.gap-6(class="grid-cols-1 lg:grid-cols-5")
      //- Compose form
      .bg-white.rounded-xl.border.border-gray-200.p-6(class="lg:col-span-2 self-start")
        h3.font-semibold.text-gray-900.mb-1 Compose Announcement
        p.text-sm.text-gray-500.mb-4 Sends an in-app notification and a push notification to every matching user.
        form.space-y-4(method="POST" action="/admin/communication/announcements")
          div
            label.block.text-sm.font-medium.text-gray-700.mb-1(for="title") Title
            input#title.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" type="text" name="title" required maxlength="200" placeholder="New Feature: Bulk Import")
          div
            label.block.text-sm.font-medium.text-gray-700.mb-1(for="body") Message
            textarea#body.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" name="body" rows="5" required maxlength="1000" placeholder="Hey there! We just shipped…")
          div
            label.block.text-sm.font-medium.text-gray-700.mb-1(for="audience") Audience
            select#audience.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" name="audience")
              each a in audiences
                option(value=a)= a === 'all' ? 'All users' : a
          button.w-full.rounded-lg.bg-primary-600.text-white.text-sm.font-medium.flex.items-center.justify-center.gap-2(class="py-2 hover:bg-primary-700" type="submit")
            i(data-lucide="send" class="w-4 h-4")
            span Send Announcement

      //- History
      div(class="lg:col-span-3")
        h3.font-semibold.text-gray-900.mb-3 Recent Announcements
        if announcements.length === 0
          .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
            i(data-lucide="megaphone" class="w-10 h-10 mb-3")
            p.text-sm No announcements sent yet.
        else
          ul.space-y-3
            each a in announcements
              li.bg-white.rounded-xl.border.border-gray-200(class="p-4")
                .flex.items-start.justify-between.gap-3
                  div(class="min-w-0 flex-1")
                    p.text-sm.font-semibold.text-gray-900.truncate= a.title || '(no title)'
                    p.text-sm.text-gray-600.mt-1(class="line-clamp-3")= a.message
                    .flex.items-center.gap-3.mt-2.text-xs.text-gray-500
                      span #{fmtDate(a.sent_at)}
                      span ·
                      span.flex.items-center.gap-1
                        i(data-lucide="users" class="w-3 h-3")
                        | #{a.recipients} #{a.recipients === 1 ? 'recipient' : 'recipients'}
        +pagination(pagination, buildHref)
