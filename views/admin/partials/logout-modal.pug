//- Logout confirmation modal (Alpine). Toggled via `logoutOpen` on the app root.
div(x-show="logoutOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
  .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="logoutOpen = false")
  .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
    .flex.items-start.justify-between
      div
        h3.text-lg.font-semibold.text-gray-900 Logout Confirmation
        p.text-sm.text-gray-500.mt-1 Are you sure you want to log out?
      button.text-gray-400(type="button" "@click"="logoutOpen = false")
        i(data-lucide="x" class="w-5 h-5")
    .flex.justify-end.gap-3.mt-6
      button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="logoutOpen = false") Cancel
      form(method="POST" action="/admin/logout")
        button.px-4.py-2.rounded-lg.bg-red-600.text-white.text-sm.font-medium(type="submit") Yes, Logout
