extends ../layouts/app
include ../mixins/ui

block content
  div(x-data="{ createOpen: false, editOpen: false, editing: { id: 0, attribute_type: '', value: '' }, deleteOpen: false, deleting: { id: 0, value: '' } }")
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          a(href="/admin/content/banners" class="hover:text-gray-700") Content & Ads
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium= tab === 'product-attributes' ? 'Product Attributes' : 'Service Attributes'
        h1.text-2xl.font-bold.text-gray-900 Content & Ads
        p.text-gray-500.mt-1 Manage the dropdown values used when creating listings.
      button.inline-flex.items-center.gap-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="px-4 py-2 hover:bg-primary-700" type="button" "@click"="createOpen = true")
        i(data-lucide="plus" class="w-4 h-4")
        span= `Add ${tabLabel}`

    include _tabs
    include ../partials/flash

    //- Type filter chips
    .flex.flex-wrap.items-center.gap-2.mb-4
      span.text-sm.text-gray-500 Filter by type:
      a.text-sm.rounded-full.border(class=(typeFilter === null ? 'bg-primary-600 text-white border-primary-600 px-3 py-1' : 'border-gray-200 text-gray-700 hover:bg-gray-50 px-3 py-1') href=formAction) All
      each t in types
        - var isActive = (typeFilter === t)
        a.text-sm.rounded-full.border(class=(isActive ? 'bg-primary-600 text-white border-primary-600 px-3 py-1' : 'border-gray-200 text-gray-700 hover:bg-gray-50 px-3 py-1') href=`${formAction}?type=${t}`)= t.replace(/_/g, ' ')

    //- Items table
    if items.length === 0
      .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
        i(data-lucide="tag" class="w-10 h-10 mb-3")
        p.text-sm No attributes here yet.
        button.mt-3.inline-flex.items-center.gap-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="px-4 py-2 hover:bg-primary-700" type="button" "@click"="createOpen = true")
          i(data-lucide="plus" class="w-4 h-4")
          span= `Add ${tabLabel}`
    else
      .bg-white.rounded-xl.border.border-gray-200.overflow-hidden
        table.w-full.text-sm
          thead.bg-gray-50.text-gray-500
            tr
              th.text-left.font-medium(class="px-4 py-3") Type
              th.text-left.font-medium(class="px-4 py-3") Value
              th.text-left.font-medium(class="px-4 py-3") Added
              th.text-right.font-medium(class="px-4 py-3") Actions
          tbody.divide-y.divide-gray-100
            each item in items
              tr(class="hover:bg-gray-50")
                td.text-gray-700(class="px-4 py-3")
                  span.inline-flex.items-center.rounded-full.bg-primary-50.text-primary-600.font-medium(class="px-2.5 py-0.5 text-xs")= item.attribute_type.replace(/_/g, ' ')
                td.text-gray-900.font-medium(class="px-4 py-3")= item.value
                td.text-gray-500(class="px-4 py-3")= new Date(item.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
                td.text-right(class="px-4 py-3")
                  - var editPayload = JSON.stringify({ id: item.id, attribute_type: item.attribute_type, value: item.value })
                  - var deletePayload = JSON.stringify({ id: item.id, value: item.value })
                  button.inline-flex.items-center.gap-1.text-sm.text-gray-600.mr-2(class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50" type="button" "@click"=`editing = ${editPayload}; editOpen = true`)
                    i(data-lucide="pencil" class="w-4 h-4")
                  button.inline-flex.items-center.gap-1.text-sm.text-red-600(class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-red-50" type="button" "@click"=`deleting = ${deletePayload}; deleteOpen = true`)
                    i(data-lucide="trash-2" class="w-4 h-4")

    //- Create modal
    +modalShell('createOpen', `Add ${tabLabel}`, 'Add a new dropdown value for listings.')
      form(method="POST" action=formAction class="space-y-4")
        +typeSelect('attribute_type', null)
        +textField('Value', 'value', '', 'e.g. Toyota')
        +modalActions('createOpen', 'Create')

    //- Edit modal
    +modalShell('editOpen', `Edit ${tabLabel}`, 'Update the attribute.')
      form(method="POST" class="space-y-4" ":action"=`\`${formAction}/\${editing.id}/update\``)
        div
          label.block.text-sm.font-medium.text-gray-700.mb-1 Type
          select.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" name="attribute_type" "x-model"="editing.attribute_type")
            each t in types
              option(value=t)= t.replace(/_/g, ' ')
        div
          label.block.text-sm.font-medium.text-gray-700.mb-1 Value
          input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" type="text" name="value" "x-model"="editing.value")
        +modalActions('editOpen', 'Save Changes')

    //- Delete confirm modal
    +modalShell('deleteOpen', `Delete ${tabLabel}`, 'This cannot be undone.')
      p.text-sm.text-gray-600 Are you sure you want to delete
        span.font-medium.text-gray-900(x-text="deleting.value")
        | ?
      form.flex.justify-end.gap-3.mt-6(method="POST" ":action"=`\`${formAction}/\${deleting.id}/delete\``)
        button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="deleteOpen = false") Cancel
        button.px-4.py-2.rounded-lg.bg-red-600.text-white.text-sm.font-medium(type="submit") Yes, Delete

//- ===== Local mixins =======================================================

mixin modalShell(toggleVar, heading, subtitle)
  div(x-show=toggleVar x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
    .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"=`${toggleVar} = false`)
    .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
      .flex.items-start.justify-between.mb-4
        div
          h3.text-lg.font-semibold.text-gray-900= heading
          p.text-sm.text-gray-500.mt-1= subtitle
        button.text-gray-400(type="button" "@click"=`${toggleVar} = false`)
          i(data-lucide="x" class="w-5 h-5")
      block

mixin textField(label, name, value, placeholder)
  div
    label.block.text-sm.font-medium.text-gray-700.mb-1(for=name)= label
    input.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" id=name type="text" name=name value=value placeholder=placeholder required)

mixin typeSelect(name, selected)
  div
    label.block.text-sm.font-medium.text-gray-700.mb-1(for=name) Type
    select.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" id=name name=name required)
      each t in types
        option(value=t selected=(selected === t))= t.replace(/_/g, ' ')

mixin modalActions(toggleVar, submitLabel)
  .flex.justify-end.gap-3.mt-2
    button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"=`${toggleVar} = false`) Cancel
    button.px-4.py-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="hover:bg-primary-700" type="submit")= submitLabel
