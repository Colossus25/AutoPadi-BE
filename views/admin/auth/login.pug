extends ../layouts/auth

block content
  .bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-8
    .flex.flex-col.items-center.text-center
      .rounded-xl.bg-primary-600.text-white.flex.items-center.justify-center.mb-4(class="w-14 h-14")
        i(data-lucide="shield-check" class="w-7 h-7")
      h1.text-xl.font-semibold.text-gray-900 Autopadi Admin
      p.text-sm.text-gray-500.mt-1 Sign in to your admin account
    if error
      .mt-6.rounded-lg.bg-red-50.border.border-red-100.text-red-700.text-sm(class="px-4 py-3")= error
    form.mt-6.space-y-4(method="POST" action="/admin/login")
      div
        label.block.text-sm.font-medium.text-gray-700.mb-1(for="email") Email
        input#email.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" type="email" name="email" required autofocus value=(typeof email !== 'undefined' ? email : '') placeholder="admin@autopadi.com")
      div
        label.block.text-sm.font-medium.text-gray-700.mb-1(for="password") Password
        input#password.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3 focus:outline-none focus:ring-2 focus:ring-primary-500" type="password" name="password" required placeholder="••••••••")
      button.w-full.py-2.rounded-lg.bg-primary-600.text-white.text-sm.font-medium(class="hover:bg-primary-700" type="submit") Sign In
    p.text-center.text-xs.text-gray-400.mt-6 Autopadi v1.0
