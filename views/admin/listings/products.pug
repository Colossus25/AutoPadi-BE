extends ../layouts/app
include ../mixins/ui

block content
  -
    function fmtDate(d) { return d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—'; }
    function fmtPrice(p) {
      if (p == null || p === '') return '—';
      var n = Number(p);
      if (!isFinite(n)) return p;
      return '₦' + n.toLocaleString('en-US');
    }
    function userName(u) { if (!u) return 'Deleted user'; var n = ((u.first_name || '') + ' ' + (u.last_name || '')).trim(); return n || u.email || ('User #' + u.id); }
    function thumbFor(p) {
      if (Array.isArray(p.media) && p.media.length > 0) return p.media[0];
      return null;
    }
    function buildHref(page) { return '/admin/listings/products?page=' + page; }

  div
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          a(href="/admin/listings/products" class="hover:text-gray-700") Listings
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Products
        h1.text-2xl.font-bold.text-gray-900 Listings
        p.text-gray-500.mt-1 All Auto Dealer product listings on the platform.

    include _tabs
    include ../partials/flash

    //- Table
    if products.length === 0
      .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
        i(data-lucide="package" class="w-10 h-10 mb-3")
        p.text-sm No products yet.
    else
      .bg-white.rounded-xl.border.border-gray-200.overflow-hidden
        table.w-full.text-sm
          thead.bg-gray-50.text-gray-500
            tr
              th.text-left.font-medium(class="px-4 py-3") Product
              th.text-left.font-medium(class="px-4 py-3") Store
              th.text-left.font-medium(class="px-4 py-3") Owner
              th.text-right.font-medium(class="px-4 py-3") Price
              th.text-left.font-medium(class="px-4 py-3") Details
              th.text-right.font-medium(class="px-4 py-3") Engagement
              th.text-left.font-medium(class="px-4 py-3") Listed
          tbody.divide-y.divide-gray-100
            each p in products
              - var thumb = thumbFor(p)
              tr(class="hover:bg-gray-50")
                td(class="px-4 py-3")
                  .flex.items-center.gap-3
                    if thumb
                      img.rounded-lg.bg-gray-100.object-cover.shrink-0(class="w-10 h-10" src=thumb alt="")
                    else
                      .rounded-lg.bg-gray-100.flex.items-center.justify-center.text-gray-300.shrink-0(class="w-10 h-10")
                        i(data-lucide="package" class="w-4 h-4")
                    div(class="min-w-0")
                      p.text-gray-900.font-medium.truncate= p.title || 'Untitled'
                      if p.category && p.category.length
                        p.text-xs.text-gray-500.truncate= (Array.isArray(p.category) ? p.category : [p.category]).join(', ')
                td.text-gray-700(class="px-4 py-3")= p.store ? (p.store.name || ('Store #' + p.store.id)) : '—'
                td.text-gray-700(class="px-4 py-3")= userName(p.created_by)
                td.text-right.text-gray-900.font-medium(class="px-4 py-3")= fmtPrice(p.price)
                td.text-xs.text-gray-500(class="px-4 py-3")
                  if p.make
                    span= p.make
                  if p.year
                    | &nbsp;·&nbsp;
                    span= p.year
                  if p.condition
                    | &nbsp;·&nbsp;
                    span= p.condition
                td.text-right.text-xs.text-gray-500(class="px-4 py-3")
                  | #{(p.clicks_count || 0) + ' clicks · ' + (p.enquiries_count || 0) + ' enquiries'}
                td.text-gray-700(class="px-4 py-3")= fmtDate(p.created_at)

    +pagination(pagination, buildHref)
