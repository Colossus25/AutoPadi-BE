extends ../layouts/app
include ../mixins/ui

block content
  -
    function fmtDate(d) { return d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—'; }
    function userName(u) { if (!u) return 'Deleted user'; var n = ((u.first_name || '') + ' ' + (u.last_name || '')).trim(); return n || u.email || ('User #' + u.id); }
    function thumbFor(s) {
      if (Array.isArray(s.media) && s.media.length > 0) return s.media[0];
      return null;
    }
    function buildHref(page) { return '/admin/listings/services?page=' + page + (statusFilter ? '&status=' + statusFilter : ''); }

  div(x-data="{ approveOpen: false, approving: { id: 0, name: '' }, rejectOpen: false, rejecting: { id: 0, name: '' } }")
    //- Header
    .flex.items-start.justify-between.mb-6
      div
        nav.flex.items-center.gap-2.text-sm.text-gray-500.mb-2
          a(href="/admin" class="hover:text-gray-700") Dashboard
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          a(href="/admin/listings/products" class="hover:text-gray-700") Listings
          i(data-lucide="chevron-right" class="w-3.5 h-3.5")
          span.text-gray-900.font-medium Services
        h1.text-2xl.font-bold.text-gray-900 Listings
        p.text-gray-500.mt-1 Service listings need admin approval before going live.
      if pendingCount > 0
        a.inline-flex.items-center.gap-2.rounded-lg.bg-amber-50.text-amber-700.text-sm.font-medium(class="px-4 py-2 hover:bg-amber-100" href="/admin/listings/services?status=pending")
          i(data-lucide="clock" class="w-4 h-4")
          span= `${pendingCount} pending review`

    include _tabs
    include ../partials/flash

    //- Status filter chips
    .flex.flex-wrap.items-center.gap-2.mb-4
      span.text-sm.text-gray-500 Filter by status:
      a.text-sm.rounded-full.border(class=(statusFilter === null ? 'bg-primary-600 text-white border-primary-600 px-3 py-1' : 'border-gray-200 text-gray-700 hover:bg-gray-50 px-3 py-1') href='/admin/listings/services') All
      each s in serviceStatuses
        - var isActive = (statusFilter === s)
        a.text-sm.rounded-full.border(class=(isActive ? 'bg-primary-600 text-white border-primary-600 px-3 py-1' : 'border-gray-200 text-gray-700 hover:bg-gray-50 px-3 py-1') href=`/admin/listings/services?status=${s}`)= s

    //- Table
    if services.length === 0
      .bg-white.rounded-xl.border.border-gray-200.flex.flex-col.items-center.text-center.text-gray-400(class="p-12")
        i(data-lucide="wrench" class="w-10 h-10 mb-3")
        p.text-sm No services match this filter.
    else
      .bg-white.rounded-xl.border.border-gray-200.overflow-hidden
        table.w-full.text-sm
          thead.bg-gray-50.text-gray-500
            tr
              th.text-left.font-medium(class="px-4 py-3") Service
              th.text-left.font-medium(class="px-4 py-3") Provider
              th.text-left.font-medium(class="px-4 py-3") Region
              th.text-left.font-medium(class="px-4 py-3") Status
              th.text-left.font-medium(class="px-4 py-3") Submitted
              th.text-right.font-medium(class="px-4 py-3") Actions
          tbody.divide-y.divide-gray-100
            each s in services
              - var thumb = thumbFor(s)
              - var who = userName(s.created_by)
              - var payload = JSON.stringify({ id: s.id, name: s.name || ('Service #' + s.id) })
              tr(class="hover:bg-gray-50")
                td(class="px-4 py-3")
                  .flex.items-center.gap-3
                    if thumb
                      img.rounded-lg.bg-gray-100.object-cover.shrink-0(class="w-10 h-10" src=thumb alt="")
                    else
                      .rounded-lg.bg-gray-100.flex.items-center.justify-center.text-gray-300.shrink-0(class="w-10 h-10")
                        i(data-lucide="wrench" class="w-4 h-4")
                    div(class="min-w-0")
                      p.text-gray-900.font-medium.truncate= s.name || 'Untitled service'
                      if s.category && s.category.length
                        p.text-xs.text-gray-500.truncate= (Array.isArray(s.category) ? s.category : [s.category]).join(', ')
                td(class="px-4 py-3")
                  p.text-gray-900.font-medium= who
                  if s.created_by && s.created_by.email
                    p.text-xs.text-gray-500= s.created_by.email
                td.text-gray-700(class="px-4 py-3")= s.region || '—'
                td(class="px-4 py-3")
                  +statusPill(s.status)
                  if s.status === 'rejected' && s.rejection_reason
                    p.text-xs.text-gray-500.mt-1.italic(title=s.rejection_reason)= 'Reason: ' + (s.rejection_reason.length > 40 ? s.rejection_reason.slice(0, 40) + '…' : s.rejection_reason)
                td.text-gray-700(class="px-4 py-3")= fmtDate(s.created_at)
                td.text-right(class="px-4 py-3")
                  if s.status === 'pending'
                    button.inline-flex.items-center.gap-1.text-sm.text-green-700.mr-2(class="px-3 py-1.5 rounded-lg border border-green-100 hover:bg-green-50" type="button" "@click"=`approving = ${payload}; approveOpen = true`)
                      i(data-lucide="check" class="w-4 h-4")
                      span Approve
                    button.inline-flex.items-center.gap-1.text-sm.text-red-600(class="px-3 py-1.5 rounded-lg border border-red-100 hover:bg-red-50" type="button" "@click"=`rejecting = ${payload}; rejectOpen = true`)
                      i(data-lucide="x" class="w-4 h-4")
                      span Reject
                  else if s.status === 'approved'
                    button.inline-flex.items-center.gap-1.text-sm.text-red-600(class="px-3 py-1.5 rounded-lg border border-red-100 hover:bg-red-50" type="button" "@click"=`rejecting = ${payload}; rejectOpen = true`)
                      i(data-lucide="x" class="w-4 h-4")
                      span Reject
                  else
                    button.inline-flex.items-center.gap-1.text-sm.text-green-700(class="px-3 py-1.5 rounded-lg border border-green-100 hover:bg-green-50" type="button" "@click"=`approving = ${payload}; approveOpen = true`)
                      i(data-lucide="check" class="w-4 h-4")
                      span Re-approve

    +pagination(pagination, buildHref)

    //- Approve confirm modal
    div(x-show="approveOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="approveOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
        h3.text-lg.font-semibold.text-gray-900 Approve Service
        p.text-sm.text-gray-500.mt-1 The provider will be notified and the service goes live immediately.
        p.text-sm.text-gray-600.mt-4 Approve
          |
          span.font-medium.text-gray-900(x-text="approving.name")
          | ?
        form.flex.justify-end.gap-3.mt-6(method="POST" ":action"="`/admin/listings/services/${approving.id}/approve`")
          button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="approveOpen = false") Cancel
          button.px-4.py-2.rounded-lg.bg-green-600.text-white.text-sm.font-medium(class="hover:bg-green-700" type="submit") Approve

    //- Reject modal (with optional reason)
    div(x-show="rejectOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center")
      .absolute.inset-0.bg-black(class="bg-opacity-40" "@click"="rejectOpen = false")
      .relative.bg-white.rounded-xl.shadow-xl.w-full.p-6(class="max-w-md mx-4")
        h3.text-lg.font-semibold.text-gray-900 Reject Service
        p.text-sm.text-gray-500.mt-1 The provider will be notified; you can include a reason.
        p.text-sm.text-gray-600.mt-4 Reject
          |
          span.font-medium.text-gray-900(x-text="rejecting.name")
          | ?
        form.mt-4.space-y-4(method="POST" ":action"="`/admin/listings/services/${rejecting.id}/reject`")
          div
            label.block.text-sm.font-medium.text-gray-700.mb-1(for="reason") Reason (optional)
            textarea#reason.w-full.py-2.bg-gray-50.border.border-gray-200.rounded-lg.text-sm(class="px-3" name="reason" rows="3" placeholder="Why is this being rejected?")
          .flex.justify-end.gap-3
            button.px-4.py-2.rounded-lg.border.border-gray-200.text-sm.font-medium.text-gray-700(type="button" "@click"="rejectOpen = false") Cancel
            button.px-4.py-2.rounded-lg.bg-red-600.text-white.text-sm.font-medium(type="submit") Reject Service
