extends baseEmail

block content
  p Hi #{firstName},
  p Your subscription is expiring soon! ⏰
  p
    | Your 
    strong= planName
    | subscription will expire on 
    strong= new Date(subscriptionEndDate).toLocaleDateString()
    | .
  
  p To ensure uninterrupted access, please renew your subscription before it expires.
  
  table.table(style='width: 100%; margin: 20px 0;')
    tbody
      tr
        td Plan:
        td
          strong= planName
      tr
        td Expires On:
        td
          strong= new Date(subscriptionEndDate).toLocaleDateString()
  
  p
    a(href=`${baseUrl}/dashboard/subscriptions` style='background-color: #3498db; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block;') Renew Now
  
  p Thank you for being a valued AutoPadi customer!
